# Generated by: wfctl generate github-actions ci.yaml
# Command: wfctl generate github-actions -output .github/workflows/ ci.yaml
#
# This file is a proof-of-concept — DO NOT use as-is for releases.
# The production release pipeline is release.yml (hand-authored).
#
# ─── Coverage comparison ────────────────────────────────────────────────────
#
# COVERED by this bootstrap:
#   - CI gate: config validation (wfctl validate) + inspection (wfctl inspect)
#   - Go toolchain setup (go-version: 1.22 — note: repo uses 1.26; override needed)
#   - CD gate on v* tag push
#   - Single-arch Linux Docker build + push to ghcr.io via docker/build-push-action
#   - Multi-platform matrix for linux/amd64,linux/arm64
#   - Automatic feature detection from config (UI, auth, database flags)
#
# NOT COVERED vs release.yml (gaps):
#   - ko build (no Dockerfile, distroless base, automatic SBOM generation)
#   - cosign image signing (supply-chain attestation)
#   - Cross-compilation matrix for wfctl + workflow-lsp-server binaries
#   - Admin UI npm build + artifact packaging (workflow-admin-ui-*.tar.gz)
#   - GOPRIVATE / GONOSUMCHECK for private module access
#   - SHA-tag + major.minor tag aliases (sha-<sha>, v0.3, etc.)
#   - sha256sum checksums.txt for release assets
#   - softprops/action-gh-release with prerelease detection
#   - Homebrew tap dispatch (peter-evans/repository-dispatch → homebrew-tap)
#   - IDE plugin dispatch (→ workflow-editor)
#   - go mod tidy auto-commit + PR diff check
#   - golangci-lint job
#   - UI unit tests (vitest)
#   - Example config validation (TestExampleConfigsLoad, TestExampleConfigsValidate)
#   - workflow_call trigger for external dispatch
#   - Race-detector test run (-race flag)
#   - Coverage upload to codecov
#
# The bootstrap is a useful starting point for a new project built on the
# workflow engine — it gives you working CI/CD in ~30 lines. For the engine
# repo itself, the hand-authored release.yml covers the full release pipeline.
# ────────────────────────────────────────────────────────────────────────────

# ── ci.yml (generated) ──────────────────────────────────────────────────────
name: CI (wfctl bootstrap)
on:
  pull_request:
    branches: [main]
  push:
    branches: [main]

jobs:
  validate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: '1.26'   # bumped from generated 1.22 to match repo standard
      - name: Install wfctl
        run: go install github.com/GoCodeAlone/workflow/cmd/wfctl@latest
      - name: Validate config
        run: wfctl validate ci.yaml
      - name: Inspect config
        run: wfctl inspect ci.yaml

