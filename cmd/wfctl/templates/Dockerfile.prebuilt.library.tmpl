# syntax=docker/dockerfile:1
# Generated by wfctl scaffold dockerfile --mode=library --binary={{.Binary}}
# Base: {{.BaseImage}}
# Library mode: the application binary is built outside the container and
# copied in. The binary name is set via --binary.

FROM {{.BaseImage}} AS final

# Copy the application binary built by the CI pipeline.
COPY {{.Binary}} /{{.Binary}}

# Expose the HTTP port. Override via --expose-ports in app.yaml.
EXPOSE 8080

ENTRYPOINT ["/{{.Binary}}"]
